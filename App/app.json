{
  "expo": {
    "name": "ARPO - Auto-Regulated Progressive Overload",
    "slug": "arpoautoregulatedprogressiveoverload",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "arpoautoregulatedprogressiveoverload",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.arpoautoregulatedprogressiveoverload.app",
      "buildNumber": "4",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true
      }
    },
    "android": {
      "package": "com.arpoautoregulatedprogressiveoverload.app",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/beep.wav"
          ]
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "ARPO reads your body weight and body fat percentage from Apple Health to keep your composition metrics up to date. Smart scale data synced to Apple Health will appear automatically.",
          "NSHealthUpdateUsageDescription": "ARPO saves your workout sessions to Apple Health."
        }
      ],
      "react-native-health-connect"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {
        "projectId": "ea40d9fc-045c-45b5-a228-e71dbb0eb3b7"
      }
    },
    "owner": "languagevox"
  }
}
